{
  "name": "estacoda",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KemetResearch/EstaCoda.git"
  },
  "bugs": {
    "url": "https://github.com/KemetResearch/EstaCoda/issues"
  },
  "homepage": "https://estacoda.kemetresearch.com",
  "engines": {
    "node": ">=22.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skills",
    "assets",
    "workers",
    "acp_registry",
    "scripts/install.sh",
    "scripts/setup-estacoda.sh",
    "scripts/uninstall.sh",
    "scripts/estacoda-wrapper.sh",
    "scripts/whatsapp-bridge/package.json",
    "scripts/whatsapp-bridge/package-lock.json",
    "scripts/whatsapp-bridge/bridge.js",
    "scripts/whatsapp-bridge/README.md",
    "README.md",
    "LICENSE",
    "NOTICE",
    "package.json"
  ],
  "bin": {
    "estacoda": "./dist/index.js"
  },
  "scripts": {
    "skills:catalog": "tsx scripts/build-skills-catalog.ts",
    "typecheck": "tsc --noEmit",
    "clean:dist": "node scripts/clean-dist.mjs",
    "build": "pnpm run clean:dist && tsc -p tsconfig.build.json",
    "verify:local-bin": "pnpm run build && head -n 1 dist/index.js && node dist/index.js --version && node dist/index.js --help",
    "pack:dry-run": "pnpm run build && npm pack --dry-run",
    "verify:package-bin": "scripts/verify-package-bin.sh",
    "validate:install": "scripts/validate-install-update.sh",
    "validate:source-install": "scripts/validate-source-install.sh",
    "validate:uninstall": "pnpm exec vitest run src/lifecycle/uninstall.test.ts src/cli/uninstall-command.test.ts",
    "validate:docker": "scripts/validate-docker-image.sh",
    "validate:homebrew": "scripts/validate-homebrew-handoff.sh",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "dev:bun": "bun src/index.ts",
    "smoke": "node --import tsx src/smoke.ts",
    "smoke:dist": "node dist/smoke.js",
    "smoke:bun": "bun src/smoke.ts",
    "audit:esm": "node scripts/audit-esm.mjs dist",
    "audit:runtime-imports": "node scripts/audit-runtime-imports.mjs",
    "test": "vitest run",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:bun": "bun ./node_modules/vitest/vitest.mjs run",
    "alpha:harness": "node --import tsx scripts/internal-alpha.ts",
    "alpha:harness:bun": "bun scripts/internal-alpha.ts",
    "eval:substrate": "node --import tsx scripts/eval-substrate.ts",
    "eval:substrate:bun": "bun scripts/eval-substrate.ts",
    "eval:fixtures": "node --import tsx scripts/run-eval-fixtures.ts",
    "provider:hardening": "node --import tsx scripts/provider-hardening.ts",
    "provider:hardening:bun": "bun scripts/provider-hardening.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "discord.js": "^14.26.4"
  }
}
